{
  "framework": "nextjs",
  "rewrites": [
    {
      "source": "/manychat-tag",
      "destination": "/api/manychat-tag"
    },
    {
      "source": "/instagram-webhook",
      "destination": "/api/instagram-webhook"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/mozi-sync",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/ads-tracker-sync",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/monthly-financials",
      "schedule": "0 9 1 * *"
    },
    {
      "path": "/api/cron/daily-coacher-digest",
      "schedule": "30 8 * * *"
    },
    {
      "path": "/api/cron/daily-coacher-summaries",
      "schedule": "0 3 */3 * *"
    },
    {
      "path": "/api/cron/check-in-weekly-digest",
      "schedule": "0 11 * * 0"
    },
    {
      "path": "/api/cron/weekly-meetings-report",
      "schedule": "0 20 * * 0"
    },
    {
      "path": "/api/cron/variations-pregenerate",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/sales-quick-sync",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/cron/content-pipeline",
      "schedule": "0 */2 * * *"
    },
    {
      "path": "/api/cron/daily-metrics-eod",
      "schedule": "0 5,6 * * *"
    }
  ]
}
